{
  "name": "rook-zero-multiplayer-server-example",
  "private": true,
  "description": "Example Express and Socket.IO multiplayer server built on top of rook-zero.",
  "scripts": {
    "build": "npx tsc -p tsconfig.json",
    "start": "node dist/examples/multiplayer-server/src/server.js",
    "dev": "npx ts-node -P tsconfig.json src/server.ts",
    "test:chess-engine": "npx ts-node -P tsconfig.json src/tests/chessEngineValidator.ts",
    "test:xy-users": "npx ts-node -P tsconfig.json src/tests/xyUserTest.ts",
    "test:game-simulation": "npx ts-node -P tsconfig.json src/tests/gameSimulation.ts",
    "test:basic": "npx ts-node -P tsconfig.json src/tests/basicTest.ts",
    "test:castling": "npx ts-node -P tsconfig.json src/tests/castlingTest.ts",
    "test:all": "npm run test:chess-engine && npm run test:xy-users && npm run test:game-simulation && npm run test:castling",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "redis": "^4.6.12",
    "rook-zero": "file:../..",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
