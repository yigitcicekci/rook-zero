{
  "name": "chess-engine-test",
  "version": "1.0.0",
  "description": "Chess Engine Test with Socket.IO and Redis",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "npx ts-node src/server.ts",
    "test": "jest",
    "test:chess-engine": "npx ts-node src/tests/chessEngineValidator.ts",
    "test:xy-users": "npx ts-node src/tests/xyUserTest.ts",
    "test:game-simulation": "npx ts-node src/tests/gameSimulation.ts",
    "test:basic": "npx ts-node src/tests/basicTest.ts",
    "test:castling": "npx ts-node src/tests/castlingTest.ts",
    "test:all": "npm run test:chess-engine && npm run test:xy-users && npm run test:game-simulation && npm run test:castling",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "redis": "^4.6.12",
    "uuid": "^9.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.7",
    "@types/cors": "^2.8.17",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "ts-jest": "^29.1.1"
  },
  "keywords": [
    "chess",
    "engine",
    "socket.io",
    "redis",
    "test"
  ],
  "author": "Your Name",
  "license": "MIT"
} 