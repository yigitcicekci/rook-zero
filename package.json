{
  "name": "@yigitcicekci/rook-zero",
  "version": "1.0.5",
  "description": "Chess rules, notation, and Elo rating library with strict validation and legal move generation.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist rook-zero-*.tgz",
    "test": "jest --runInBand --watchman=false",
    "demo:dev": "npm --prefix apps/demo-web run dev",
    "demo:build": "npm --prefix apps/demo-web run build",
    "example:build": "npm --prefix examples/multiplayer-server run build",
    "example:dev": "npm --prefix examples/multiplayer-server run dev",
    "example:start": "npm --prefix examples/multiplayer-server run start",
    "publish:npm": "npm publish --userconfig=/Users/yigitcicekci/.npmrc --registry=https://registry.npmjs.org --access public",
    "publish:github": "npm publish --userconfig=.npmrc.github --registry=https://npm.pkg.github.com",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "rook-zero",
    "chess",
    "chess-engine",
    "typescript",
    "fen",
    "san",
    "uci",
    "pgn",
    "elo",
    "rating",
    "move-validation",
    "board-game"
  ],
  "author": "Yigit Cicekci",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yigitcicekci/rook-zero.git"
  },
  "homepage": "https://github.com/yigitcicekci/rook-zero#readme",
  "bugs": {
    "url": "https://github.com/yigitcicekci/rook-zero/issues"
  },
  "license": "MIT"
}
